<div class="container">
    <h1 class="form-label text-center">@Model["Categories"] Recipes</h1>
</div>
<ul class="entries" id="entries">
    <div class="container">
        <div class="row">
            @for (var i = 0; i < Model["Recipe"].length; i++)
            {
                {<div class="col-4">
                     <div class="text-center">
                         <div class="card" style="width: 18rem;">
                             <div class="card-body">
                                 <a>@Model["Recipe"][i]["Title"]</a>
                             </div>
                             <div class="card-footer">
                                 <form enctype="multipart/form-data" asp-controller="Home" asp-action="ViewRecipePage" method="get" class="mt-3">
                                     <input type="hidden" name="recipe_id" value={{ recipe.id }}>
                                     <button type="submit" style="margin-left:100px" class="btn btn-sm">Details</button>
                                 </form>
                             </div>
                         </div>
                     </div>
                 </div>
                }
            }
            <div>
                @if (Model["Recipe"].length == 0)
                {
                    {<p>Nothing in here so far</p>}
                }
            </div>
        </div>
    </div>
</ul>